generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// 1. TABELA ALUNO

model Aluno {
  id           Int           @id @default(autoincrement())
  nome         String
  matricula    String        @unique
  email        String        @unique
  
  pacientes    Paciente[]    
  solicitacoes Solicitacao[] 
}


// 2. TABELA PACIENTE (População)

model Paciente {
  id                 Int           @id @default(autoincrement())
  nome               String
  telefone           String
  status             String        @default("AGUARDANDO") 
  
  alunoResponsavelId Int?          
  aluno              Aluno?        @relation(fields: [alunoResponsavelId], references: [id])
  
  solicitacoes       Solicitacao[]
}


// 3. TABELA SOLICITAÇÃO 

model Solicitacao {
  id         Int      @id @default(autoincrement())
  data       DateTime @default(now()) 
  status     String   @default("PENDENTE") 
  
  alunoId    Int
  pacienteId Int
  aluno      Aluno    @relation(fields: [alunoId], references: [id])
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
}