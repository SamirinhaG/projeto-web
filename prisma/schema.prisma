generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id    Int    @id @default(autoincrement())
  nome  String
  login String @unique
  senha String 
}

model Aluno {
  id        Int    @id @default(autoincrement())
  nome      String
  matricula String @unique
  email     String @unique
  senha     String // Novo campo adicionado
}

model Paciente {
  id      Int    @id @default(autoincrement())
  nome    String
  status  String @default("AGUARDANDO")
}